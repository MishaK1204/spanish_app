# Copy to .env.api and fill in for production
PORT=3000

DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=spanish

# Set true once (first boot) to create tables, then set back to false.
DB_SYNCHRONIZE=false

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_SECONDS=604800

# Optional: point to mounted vocabulary JSON directory in the container
# VOCABULARY_DATA_DIR=/data/categories
