# PostgreSQL — copy to .env and adjust
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=spanish

# Set to true once so tables are created (users, word_categories, words), then turn off for production.
# If synchronize stays false, create missing tables manually, for example:
#   psql -U <DB_USERNAME> -d <DB_NAME> -h <DB_HOST> -f scripts/create-users-table.sql
#   psql -U <DB_USERNAME> -d <DB_NAME> -h <DB_HOST> -f scripts/create-learned-words-table.sql
DB_SYNCHRONIZE=false

# JWT for /auth/login and /auth/register responses
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_SECONDS=604800

# Optional: folder with *.json category files (default: ../Categories and words from backend/)
# VOCABULARY_DATA_DIR=/absolute/path/to/Categories and words
